@article{bjornsson_span_2026,
	title = {{\textless}span style="font-variant:small-caps;"{\textgreater}{ASH}{\textless}/span{\textgreater} : {A} {Multi}‐{Scale}, {Multi}‐{Theory} {Modeling} {Program}},
