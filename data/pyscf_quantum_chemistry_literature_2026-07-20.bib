	file = {Preprint PDF:D\:\\Zotero\\storage\\AFMDEWTP\\Li和Chan - 2025 - Accurate QMMM Molecular Dynamics for Periodic Systems in GPU4P span style=font-variantsmall-caps.pdf:application/pdf},
