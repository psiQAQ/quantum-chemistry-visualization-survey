@article{werner_molpro_2020,
	title = {The {Molpro} quantum chemistry package},
	volume = {152},
	issn = {0021-9606, 1089-7690},
	url = {https://pubs.aip.org/jcp/article/152/14/144107/197853/The-Molpro-quantum-chemistry-package},
	doi = {10.1063/5.0005081},
	abstract = {Molpro is a general purpose quantum chemistry software package with a long development history. It was originally focused on accurate wavefunction calculations for small molecules but now has many additional distinctive capabilities that include, inter alia, local correlation approximations combined with explicit correlation, highly efficient implementations of single-reference correlation methods, robust and efficient multireference methods for large molecules, projection embedding, and anharmonic vibrational spectra. In addition to conventional input-file specification of calculations, Molpro calculations can now be specified and analyzed via a new graphical user interface and through a Python framework.},
	language = {en},
	number = {14},
	journal = {The Journal of Chemical Physics},
	author = {Werner, Hans-Joachim and Knowles, Peter J. and Manby, Frederick R. and Black, Joshua A. and Doll, Klaus and Heßelmann, Andreas and Kats, Daniel and Köhn, Andreas and Korona, Tatiana and Kreplin, David A. and Ma, Qianli and Miller, Thomas F. and Mitrushchenkov, Alexander and Peterson, Kirk A. and Polyak, Iakov and Rauhut, Guntram and Sibaev, Marat},
	month = apr,
	year = {2020},
	pages = {144107},
	annote = {Survey 定向阅读问题
关联模块： Molpro、高精度与多参考工作流
问题生成依据： 题名与 Zotero 摘要
阅读时请直接在每个"回答"后补充结论，并记录对应页码、图表或原文位置。
阅读问题
问题 1
Molpro 的优势任务中，哪些输出最需要与其他程序交叉核验或可视化？
回答：
Molpro 的核心优势包括高度精确的波函数方法——CCSD(T)-F12、MRCI-F12、CASPT2-F12（Sec. II），以及局域关联近似 PNO-LCCSD(T)-F12（Sec. II.A, Table V）。这些方法输出的激发能（EOM-CCSD）、振子强度（Sec. II.D）、跃迁密度矩阵（Sec. II.D）、自旋-轨道耦合（Sec. II.H）、SAPT 能量分解（Sec. IV.C）及其非简谐振动谱（Sec. VI）都是需要跨程序验证的关键量。特别是（1）大体系 PNO 局域相关方法的能量和梯度，常需与 Canonical 计算对照验证 Local 近似的误差（Table V 中对比了 PNO-CASPT2 与 Canonical CASPT2 的 ΔE）；(2) 多参考势能面（IC-MRCI, Sec. II.F）的激发态能量和锥形交叉结构；(3) 含频响应性质（Sec. II.C）在界面可视化中需要与实验谱图交叉核验。
问题 2
高阶相关与多参考计算的轨道/态数据在格式和元数据上有哪些特殊要求？
回答：
Molpro 采用多种格式管理高阶数据：(1) FCIdump 格式（Sec. IX.A）以分子轨道基下的 Hamiltonian 矩阵元表示，用于连接 MRCC、NECI 等外部程序，支持 model Hamiltonians 和 frozen virtual 近似；(2) molpro-output XML schema（Sec. VIII.D）结构化输出能量、几何、振动频率、基组和轨道信息，支持 pysjef Python 模块进行后处理；(3) CASSCF（Sec. II.F）轨道可继续用于单态或多态 PNO-CASPT2 计算；(4) 激发态密度矩阵和跃迁密度矩阵（Sec. II.D）用于导出偶极矩、振子强度等一阶性质；(5) 多参考计算中需要明确活性空间定义、态平均权重、自旋多重度等元数据；(6) 对 PNO 方法，额外需要 PNO 占据数阈值、局域化方案等参数描述。Molpro 本身不含 Molden/cube 等通用可视化格式的标准导出，但 XML 输出一定程度上弥补了这一缺口。
问题 3
商业许可、输入语言和集群运行是否构成采用独立可视化工具的障碍？
回答：
Molpro 是商业软件（许可证不在本文公开范围内），其输入语言为 ASCII 命令式（Sec. VIII.A），支持 xyz 和 z-matrix 格式的几何输入，对标准计算而言较为简洁（Table VII 给出了 DFT 和 CC 的典型输入）。集群运行方面：(1) gmolpro GUI（Sec. VIII.C）仅支持 Linux/macOS，无原生 Windows 版本，限制了部分用户的可视化环境选择；(2) PQSMol 界面支持远程作业提交（Sec. VIII.C），但交互式可视化依赖 PQSMol viewer；(3) SJEF（Simple Job Execution Framework, Sec. VIII.D）提供了 C++/C/Python 绑定及命令行工具，使外部工具可通过 pysjef 接口读取 Molpro 输出，降低了开发独立可视化工具的对接成本。总体而言，商业许可和输入语言本身的壁垒较低，但 XML 解析和 Python 绑定的存在使得独立可视化工具的开发可行。
阅读后回填
对问卷题目或选项的影响：Molpro 的 XML 输出和 pysjef/Python 接口为外部可视化工具提供了可行路径，可增补关于"解析标准化输出格式意愿"的题目可转化为访谈追问的内容：用户对 gmolpro 的跨平台支持和 PQSMol viewer 协作的满意度关键证据页码/图表：Sec. VIII.C (gmolpro), Sec. VIII.D (SJEF/pysjef/XML schema), Sec. IX.A (FCIdump), Table V (PNO-CASPT2 benchmark), Figure 5 (GUI 截图)仍未解决的问题：Molpro 的具体许可证价格和条款未在本文披露；XML schema 对可视化工具的通用性有待验证
综合摘要
本文（Werner et al., J. Chem. Phys. 152, 144107, 2020）系统综述了 Molpro 量子化学包的核心方法体系：单参考高精度相关方法（CCSD(T)-F12, PNO-LCCSD(T)-F12）、多参考方法（IC-MRCI, CASPT2-F12, CASSCF）、投影嵌入（Sec. IV.B）、SAPT 能量分解（Sec. IV.C）及非简谐振动谱（Sec. VI）。Molpro 的差异化竞争力在于其对大分子的局域相关方法与显式相关（F12）技术的深度融合。在可视化与互操作性方面，Molpro 通过 molpro-output XML 模式和 pysjef Python 模块（Sec. VIII.D）提供了结构化输出的后处理途径，FCIdump 格式（Sec. IX.A）支持多程序间 Hamiltonian 矩阵元交换，同时 gmolpro GUI（Sec. VIII.C）和 PQSMol 界面集成了结构构建与远程提交功能。这些特征表明，Molpro 的 XML+Pysjef 接口为独立外部可视化工具的构建奠定了良好基础。},
	file = {全文:D\:\\Zotero\\storage\\G6EZMXAI\\Werner 等 - 2020 - The Molpro quantum chemistry package.pdf:application/pdf},
}

@article{seritan_span_2021,
	title = {{\textless}span style="font-variant:small-caps;"{\textgreater}{TeraChem}{\textless}/span{\textgreater} : {A} graphical processing unit {\textless}span style="font-variant:small-caps;"{\textgreater}‐accelerated{\textless}/span{\textgreater} electronic structure package for {\textless}span style="font-variant:small-caps;"{\textgreater}large‐scale{\textless}/span{\textgreater} ab initio molecular dynamics},
	volume = {11},
	issn = {1759-0876, 1759-0884},
	shorttitle = {{TeraChem}},
	url = {https://wires.onlinelibrary.wiley.com/doi/10.1002/wcms.1494},
	doi = {10.1002/wcms.1494},
	abstract = {Abstract
            TeraChem was born in 2008 with the goal of providing fast on‐the‐fly electronic structure calculations to facilitate ab initio molecular dynamics studies of large biochemical systems such as photoswitchable proteins and multichromophoric antenna complexes. Originally developed for videogaming applications, graphics processing units (GPUs) offered a low‐cost parallel computer architecture that became more accessible for general‐purpose GPU computing with the release of CUDA in 2007. The evaluation of the electron repulsion integrals (ERIs) is a major bottleneck in electronic structure codes and provides an attractive target for acceleration on GPUs. Thus, highly efficient routines for evaluation of and contractions between the ERIs and density matrices were implemented in TeraChem. Electronic structure methods were developed and implemented to leverage these integral contraction routines, resulting in the first quantum chemistry package designed from the ground up for GPUs. This GPU acceleration makes TeraChem capable of performing large‐scale ground and excited state calculations in the gas and condensed phase. Today, TeraChem's speed forms the basis for a suite of quantum chemistry applications, including optimization and dynamics of proteins, automated and interactive chemical discovery tools, and large‐scale nonadiabatic dynamics simulations.
            
              This article is categorized under:
              
                
                  Electronic Structure Theory {\textgreater} Ab Initio Electronic Structure Methods
                
                
                  Software {\textgreater} Quantum Chemistry
                
                
                  Structure and Mechanism {\textgreater} Computational Biochemistry and Biophysics},
	language = {en},
	number = {2},
	journal = {WIREs Computational Molecular Science},
	author = {Seritan, Stefan and Bannwarth, Christoph and Fales, Bryan S. and Hohenstein, Edward G. and Isborn, Christine M. and Kokkila‐Schumacher, Sara I. L. and Li, Xin and Liu, Fang and Luehr, Nathan and Snyder, James W. and Song, Chenchen and Titov, Alexey V. and Ufimtsev, Ivan S. and Wang, Lee‐Ping and Martínez, Todd J.},
	month = mar,
	year = {2021},
	pages = {e1494},
	annote = {Survey 定向阅读问题
关联模块： TeraChem GPU 加速与交互式计算
问题生成依据： 题名与 Zotero 摘要
阅读时请直接在每个"回答"后补充结论，并记录对应页码、图表或原文位置。
阅读问题
问题 1
TeraChem 的 GPU 加速对可视化数据生成速度和规模有何影响？
回答：

实时/交互式计算（摘要, p.1）：TeraChem 的速度"forms the basis for automated and interactive chemical discovery tools"——这使得"实时可视化"成为可能，即计算完成后立即可视化。
大规模非绝热动力学（Section, p.6-7）："several dozen trajectories can be run for hundreds of femtoseconds using a multireference correlation method"——大规模轨迹产生大量需要可视化的数据。
Python socket 接口（Section, p.3）："a new language-agnostic socket-based interface allows TeraChem to run as a server for single-point calculations, providing access to fast electronic structure from high-level languages like Python"——这意味着可视化工具可以直接通过 socket 从 TeraChem 获取数据，无需文件解析。
GPU 原生设计：TeraChem 是"the first quantum chemistry package designed from the ground up for GPUs"——GPU 加速使大体系（数百原子）的高精度方法计算成为可能。

问题 2
TeraChem 的 Molden 输出和 NBO 接口提供了什么文件格式先例？
回答：

Molden 格式（Section 2, p.4）："TeraChem Molden outputs from spherical basis SCF calculations can be used to run simplified TD-DFT calculations with the sTDA program"——Molden 格式是量子化学中通用的分子轨道/密度格式，被多个可视化和分析工具支持（如 Molden 本身、Gabedit、Avogadro）。
NBO 接口（Section 2, p.4）："TeraChem is interfaced with NBO 6.0 for more advanced natural bond order (NBO) and natural population analyses"——NBO 分析产生自然轨道、自然键轨道等科学语义，可被可视化。
对引擎无关工具的启示：Molden 格式已是一个成功"跨程序标准化格式"的案例——它被多个 QC 程序和支持。这为问卷 D 模块提供了"标准化格式可行性"的实证。

问题 3
socket 接口和"TeraChem as server"模式对引擎无关可视化的架构启示是什么？
回答：

计算-可视化分离：TeraChem 的 socket 接口将计算引擎与前端分离——这与"引擎无关可视化"的核心架构完全一致。
语言无关性："language-agnostic socket-based interface"意味着可视化工具可以使用任何语言编写，只需实现 socket 通信协议。
工作流集成："deploy TeraChem in flexible workflows on modern distributed computing resources"——分布式环境中，计算和可视化可能在不同机器上执行。
对比 PySCF：PySCF 通过在同一个 Python 进程中调用实现类似"无缝集成"，而 TeraChem 通过 socket 实现进程间通信——两种不同的"引擎无关"架构方案。

阅读后回填

对问卷题目或选项的影响：
 
 Q16（格式覆盖面）：Molden 格式是必须列出的跨程序格式。
 D 模块（引擎无关）：TeraChem 的 socket 接口是"引擎无关"工作流的典型案例，可作为问题背景介绍。
 

可转化为访谈追问的内容：
 
 用户是否使用 TeraChem 的 socket 接口与 Python 交互？
 用户使用哪些工具可视化 TeraChem 的 Molden 输出？
 GPU 加速是否改变了用户对"可接受等待时间"的预期？
 

关键证据页码/图表：
 
 Section 2 (p.4)：Molden 输出和 NBO 接口。
 Section (p.3)：socket 服务器接口描述。
 Figure 8 (p.7)：大规模 AIMS 轨迹。
 

仍未解决的问题：
 
 TeraChem socket 接口是否支持波函数信息（轨道系数、密度）的传输？
 Molden 格式是否覆盖 TeraChem 支持的所有方法？
 


总结： TeraChem (Seritan et al., 2020) 是首个从头 GPU 设计的量子化学软件包。对本项目的关键启示：(1) TeraChem 的 socket 服务器接口（Section 2, p.4）提供了"语言无关的引擎-前端分离"架构——这是引擎无关工作流的一个直接范例，计算引擎和可视化前端通过标准协议通信，而非文件交换；(2) Molden 格式输出（Section 2, p.4）证明了一个跨程序标准化格式（Molden）可以成功地被多个 QC 程序采用（TeraChem、ORCA、MOLPRO 等都支持 Molden 输出），这与 QCSCHEMA 和 JSON 接口一起构成了"标准化格式可行性"的强证据；(3) GPU 加速使大规模 AIMD 和非绝热动力学成为可能，产生大量轨迹和激发态数据需要可视化；(4) 与 PySCF 的纯 Python 路线不同，TeraChem 的 C++/CUDA 核心通过 socket 暴露给 Python 的架构设计，是问卷 D 模块中"计算后端与可视化前端分离"这一概念的具体实证。},
	file = {已提交版本:D\:\\Zotero\\storage\\STKKHKCD\\Seritan 等 - 2021 - TeraChem  A graphical processing unit span style=fo.pdf:application/pdf},
}

@article{zahariev_general_2023,
	title = {The {General} {Atomic} and {Molecular} {Electronic} {Structure} {System} ({GAMESS}): {Novel} {Methods} on {Novel} {Architectures}},
	volume = {19},
	issn = {1549-9618, 1549-9626},
	shorttitle = {The general atomic and molecular electronic structure system ({GAMESS})},
	url = {https://pubs.acs.org/doi/10.1021/acs.jctc.3c00379},
	doi = {10.1021/acs.jctc.3c00379},
	language = {en},
	number = {20},
	journal = {Journal of Chemical Theory and Computation},
	author = {Zahariev, Federico and Xu, Peng and Westheimer, Bryce M. and Webb, Simon and Galvez Vallejo, Jorge and Tiwari, Ananta and Sundriyal, Vaibhav and Sosonkina, Masha and Shen, Jun and Schoendorff, George and Schlinsog, Megan and Sattasathuchana, Tosaporn and Ruedenberg, Klaus and Roskop, Luke B. and Rendell, Alistair P. and Poole, David and Piecuch, Piotr and Pham, Buu Q. and Mironov, Vladimir and Mato, Joani and Leonard, Sam and Leang, Sarom S. and Ivanic, Joe and Hayes, Jackson and Harville, Taylor and Gururangan, Karthik and Guidez, Emilie and Gerasimov, Igor S. and Friedl, Christian and Ferreras, Katherine N. and Elliott, George and Datta, Dipayan and Cruz, Daniel Del Angel and Carrington, Laura and Bertoni, Colleen and Barca, Giuseppe M. J. and Alkan, Melisa and Gordon, Mark S.},
	month = oct,
	year = {2023},
	pages = {7031--7055},
	annote = {Survey 定向阅读问题关联模块： GAMESS、新架构与高性能方法阅读时请直接在每个"回答"后补充结论，并记录对应页码、图表或原文位置。阅读问题问题 1GAMESS 针对 CPU、GPU 和新架构的优化覆盖哪些方法与规模？回答： GAMESS 的 CPU/GPU 优化覆盖广泛：HF SCF 解析 Hessian 的 MPI 并行始于 1990 年代初（Sec. 1）；RI-MP2 和 CCSD(T) 通过密度拟合和碎片化方法降低标度（Sec. 1）；OpenMP 直接 GPU 卸载（Sec. 3.1）成功应用于 HF 和 RI-MP2 及相关积分；cube 分区方案（Sec. 8）递归拆分含分子的初始立方体作为 GPU 卸载基础；EFP/FMO/EFMO 碎片方法采用 MPI ranks + threads + accelerator 混合并行（Sec. 3.2）；Julia 语言接口（Sec. 10）提供高性能脚本化支持。规模方面覆盖从笔记本电脑到大规模并行集群，包括 AMD GPU 支持（Sec. 3.1），CCSD(T) 采用 RI 近似后可用于中等分子。问题 2碎片化、密度拟合等近似需要哪些额外元数据才能解释可视化结果？回答： 碎片化方法（EFP, FMO, EFMO）产生的能量分解（Sec. 3.2）需要以下元数据：(1) 基组信息和占据 LMO 及其 Fock 矩阵和质心坐标（Sec. 2.2）；(2) 电荷转移贡献需要占据和虚 LMO 信息；(3) 密度拟合/RI 近似（Sec. 2.4.1）需要辅助基组定义和 RI 误差评估；(4) EFP 中非刚性内部自由度需额外的解析梯度信息（Sec. 3.2）；(5) 多层 QM-EFP 实现需要各层边界描述；(6) cube 分区（Sec. 8）用于 GPU 卸载时需空间网格元数据。问题 3传统输入输出与新高性能模块之间是否存在不一致的解析或部署门槛？回答： 存在以下不一致：(1) GPU 卸载（OpenMP）仅覆盖 HF 和 RI-MP2 等部分方法（Sec. 3.1），CCSD(T) 等高阶方法仍以 CPU 为主；(2) 碎片化方法（EFP/FMO/EFMO）的输入相对复杂，需预先定义碎片及其相互作用参数；(3) CUDA-GPU 版本依赖特定硬件（NVIDIA），AMD GPU 的支持仍在发展中；(4) Julia 接口（Sec. 10）降低了部署门槛但处于初步阶段；(5) 传统文本输入格式与新的硬件优化模块（如 cube 分区 GPU 卸载）之间缺乏自动化转换工具。阅读后回填对问卷题目的影响：可增加关于"碎片化方法元数据可视化需求"和"GPU/CPU 混合架构对可视化工具输出格式的要求"的题目可转化为访谈追问：用户对 GAMESS GPU 加速和 Julia 接口的使用体验关键证据页码/图表：Sec. 1 (并行化历史), Sec. 3.1 (GPU OpenMP), Sec. 3.2 (碎片化), Sec. 8 (cube 分区), Sec. 10 (Julia 接口)仍未解决的问题：GAMESS 是否计划支持通用可视化输出格式（Molden/Cube/XML）？综合摘要本文（Zahariev et al., J. Chem. Theory Comput. 19, 7031-7055, 2023）展示了 GAMESS 在新架构上的系统性优化：OpenMP 直接 GPU 卸载（Sec. 3.1）用于 HF 和 RI-MP2，cube 分区策略（Sec. 8）支持 GPU 加速，EFP/FMO/EFMO 碎片化方法（Sec. 3.2）实现大规模并行（MPI+OpenMP+Accelerator），以及 Julia 接口（Sec. 10）提供高性能脚本化入口。密度拟合（RI）和碎片化近似虽降低了高阶相关方法的标度，但也引入额外的元数据需求。GAMESS 在从传统 I/O 到现代混合架构的演进中，不同模块间的部署门槛和输出格式不一致仍是独立可视化工具集成的潜在障碍。},
	file = {已提交版本:D\:\\Zotero\\storage\\DPCEKNSZ\\Zahariev 等 - 2023 - The General Atomic and Molecular Electronic Structure System (GAMESS) Novel Methods on Novel Archit.pdf:application/pdf},
}

@article{matthews_coupled-cluster_2020,
	title = {Coupled-cluster techniques for computational chemistry: {The} {\textless}span style="font-variant:small-caps;"{\textgreater}{CFOUR}{\textless}/span{\textgreater} program package},
	volume = {152},
	issn = {0021-9606, 1089-7690},
	shorttitle = {Coupled-cluster techniques for computational chemistry},
	url = {https://pubs.aip.org/jcp/article/152/21/214108/198810/Coupled-cluster-techniques-for-computational},
	doi = {10.1063/5.0004837},
	abstract = {An up-to-date overview of the CFOUR program system is given. After providing a brief outline of the evolution of the program since its inception in 1989, a comprehensive presentation is given of its well-known capabilities for high-level coupled-cluster theory and its application to molecular properties. Subsequent to this generally well-known background information, much of the remaining content focuses on lesser-known capabilities of CFOUR, most of which have become available to the public only recently or will become available in the near future. Each of these new features is illustrated by a representative example, with additional discussion targeted to educating users as to classes of applications that are now enabled by these capabilities. Finally, some speculation about future directions is given, and the mode of distribution and support for CFOUR are outlined.},
	language = {en},
	number = {21},
	journal = {The Journal of Chemical Physics},
	author = {Matthews, Devin A. and Cheng, Lan and Harding, Michael E. and Lipparini, Filippo and Stopkowicz, Stella and Jagau, Thomas-C. and Szalay, Péter G. and Gauss, Jürgen and Stanton, John F.},
	month = jun,
	year = {2020},
	pages = {214108},
	annote = {Survey 定向阅读问题关联模块： CFOUR、高精度与验证阅读时请直接在每个"回答"后补充结论，并记录对应页码、图表或原文位置。阅读问题问题 1CFOUR 的耦合簇能力最适合作为什么类型的跨程序参考或基准？回答： CFOUR 的耦合簇能力最适合作为以下类型的基准：(1) CCSD(T) 能量基准——CFOUR 是 CCSD(T) 和高阶 CC（CCSDT 及以上）的基准实现之一（Sec. I, Sec. II），可作为其他程序（如 PySCF、Psi4）CC 模块的精度参考；(2) 解析梯度/频率基准——提供 CCSD 及更高级别的解析一阶和二阶导数（Sec. I, Sec. IV），可用于验证几何优化和振动频率计算；(3) 分子性质基准——NMR 化学位移（MBPT 到 CCSD(T)），自旋-自旋耦合常数（CCSD/CC3/CCSDT），极化率与超极化率（CCSD/CC3/CCSDT 的含频响应理论）（Sec. III）；(4) 基准分子集合（如 HEAT 方案）采用外推到 CBS 极限的 CC 能量，CFOUR 在此类高精度热化学方案中扮演重要角色 (Sec. VIII)；(5) 自旋-轨道耦合的非微扰处理（SO-CCSD(T)，Sec. VII），适合重元素基准计算。CFOUR 覆盖的 CC 方法从 MBPT(2) 到 CCSDTQ 及更高，是 cross-program 验证的理想参考平台。问题 2高精度能量、梯度和频率验证与三维场验证之间应怎样分工？回答： 基于 CFOUR 的能力，建议分工如下：(1) 能量验证——CFOUR 的 CCSD(T)/CBS（Sec. II）提供电子能量的"黄金标准"，适合作为 0D（标量）验证基准，用于校准其他程序的 CC 模块（如 PySCF 的 CC 代码）；(2) 梯度/频率验证——CFOUR 的解析一阶（梯度）和二阶导数（振动频率，Sec. IV）提供了分子结构和振动光谱的 1D/2D 参考，用于验证几何优化势能面和简谐/非简谐力场；(3) 三维场验证——CFOUR 的含频响应理论和超极化率（Sec. III）提供电/磁场下的 3D 响应性质，但最可靠的 3D 验证应搭配实验数据（如 VCD、旋光光谱）；(4) CFOUR 专长于分子性质的逐点高精度计算，不提供实时三维场渲染。因此 CFOUR 适合为 3D 可视化提供"参考值节点"，但实际三维场渲染仍需其他可视化工具完成。分工建议：CFOUR 负责生产高精度参考数据点（能量、梯度、频率、NMR、极化率），可视化工具负责 3D 场插值与渲染。问题 3用户是否愿意为高精度参考接受更复杂的输入和较高计算成本？回答： CFOUR 的 ZMAT 输入格式（Appendix）较为复杂，但考虑到以下因素可减轻负担：(1) 多数关键字有默认值，标准 CCSD(T) 计算仅需指定 CALC、BASIS 和 EXCITE 等少量参数；(2) 几何优化支持 Z-matrix 和笛卡尔坐标输入；(3) CFOUR 高计算成本通常预见的，因为 CCSD(T) 和更高阶方法固有的高标度（O(N{\textasciicircum}7) 或更高），目前已有局域相关方法（PNO、DLPNO）在其他程序中应用，但 CFOUR 本身的纯 canonical CC 实现保证最高精度；(4) 许可模式（Appendix：需签署协议后通过 cfour.de 获取，面向学术机构）和缺乏 GUI 可能需要额外的学习投入。对于基准验证场景（验证其他程序、高精度热化学、光谱指认），用户通常愿意为精度接受较高计算成本和输入复杂度，但对于常规生产计算，CFOUR 可能不是首选。独立可视化工具若能通过简化输入准备（如基于模板的 ZMAT 生成器）降低部署门槛，将更有利于 CFOUR 作为基准工具的使用。阅读后回填对问卷题目的影响：可增加关于"基准计算中能量 vs 梯度 vs 3D 场优先级"的题目可转化为访谈追问：用户是否愿意为了高精度基准学习 CFOUR 的 ZMAT 输入格式关键证据页码/图表：Sec. I (历史与方法范围), Sec. III (分子性质，NMR/VCD/极化率), Sec. IV (梯度与频率), Appendix (ZMAT 输入格式与许可), Sec. VII (自旋-轨道耦合), Sec. VIII (未来方向)仍未解决的问题：CFOUR 是否有计划加入局域相关方法以降低计算成本？综合摘要本文（Matthews et al., J. Chem. Phys. 152, 214108, 2020）描述了 CFOUR 程序包从 1989 年起源至今的发展。CFOUR 的核心是 CC 方法的基准级实现：从 MBPT(2) 到 CCSDTQ 及更高级别（Sec. II），包含解析梯度/频率（Sec. IV）、计算 NMR/EPR/VCD 等分子性质（Sec. III），以及非微扰自旋-轨道耦合（Sec. VII）。其 ZMAT 输入（Appendix）较为繁琐但灵活，许可面向学术和非商业机构（需签署协议）。CFOUR 最适合作为跨程序 CC 基准的提供者，其生产"参考值节点"（能量、梯度、频率、响应性质）的理想角色与独立可视化工具的 3D 渲染职能形成互补。},
	file = {Full Text PDF:D\:\\Zotero\\storage\\JPNZNHL7\\Matthews 等 - 2020 - Coupled-cluster techniques for computational chemistry The C.pdf:application/pdf},
}

@article{hourahine_dftb_2020,
	title = {{DFTB}+, a software package for efficient approximate density functional theory based atomistic simulations},
	volume = {152},
	issn = {0021-9606, 1089-7690},
	url = {https://pubs.aip.org/jcp/article/152/12/124101/953756/DFTB-a-software-package-for-efficient-approximate},
	doi = {10.1063/1.5143190},
	abstract = {DFTB+ is a versatile community developed open source software package offering fast and efficient methods for carrying out atomistic quantum mechanical simulations. By implementing various methods approximating density functional theory (DFT), such as the density functional based tight binding (DFTB) and the extended tight binding method, it enables simulations of large systems and long timescales with reasonable accuracy while being considerably faster for typical simulations than the respective ab initio methods. Based on the DFTB framework, it additionally offers approximated versions of various DFT extensions including hybrid functionals, time dependent formalism for treating excited systems, electron transport using non-equilibrium Green’s functions, and many more. DFTB+ can be used as a user-friendly standalone application in addition to being embedded into other software packages as a library or acting as a calculation-server accessed by socket communication. We give an overview of the recently developed capabilities of the DFTB+ code, demonstrating with a few use case examples, discuss the strengths and weaknesses of the various features, and also discuss on-going developments and possible future perspectives.},
	language = {en},
	number = {12},
	journal = {The Journal of Chemical Physics},
	author = {Hourahine, B. and Aradi, B. and Blum, V. and Bonafé, F. and Buccheri, A. and Camacho, C. and Cevallos, C. and Deshaye, M. Y. and Dumitrică, T. and Dominguez, A. and Ehlert, S. and Elstner, M. and Van Der Heide, T. and Hermann, J. and Irle, S. and Kranz, J. J. and Köhler, C. and Kowalczyk, T. and Kubař, T. and Lee, I. S. and Lutsker, V. and Maurer, R. J. and Min, S. K. and Mitchell, I. and Negre, C. and Niehaus, T. A. and Niklasson, A. M. N. and Page, A. J. and Pecchia, A. and Penazzi, G. and Persson, M. P. and Řezáč, J. and Sánchez, C. G. and Sternberg, M. and Stöhr, M. and Stuckenberg, F. and Tkatchenko, A. and Yu, V. W.-z. and Frauenheim, T.},
	month = mar,
	year = {2020},
	pages = {124101},
	annote = {Survey 定向阅读问题关联模块： DFTB+、近似方法与大体系阅读时请直接在每个"回答"后补充结论，并记录对应页码、图表或原文位置。阅读问题问题 1DFTB+ 的速度优势适用于哪些大体系、动力学或预筛选场景？回答： DFTB+ 的速度优势来源于从 DFT 到 DFTB 的三阶近似层级（DFTB1/DFTB2/DFTB3，Sec. II），使大体系模拟成为可能：(1) 大体系结构优化和分子动力学——XLBOMD 框架（Sec. IV.B）每次 MD 步长仅需一次对角化，结合 SCC 加速，可模拟数千原子的长时间尺度（例：Sec. VI.F 中锌指蛋白(ZnF)体系约 366 原子）；(2) 激发态性质——TD-DFTB 和 LC-DFTB（Sec. IV.C）用于光合复合物等大体系的激发能预筛选；(3) 电子输运——NEGF 方法结合 libNEGF 库（Sec. IV.D）可模拟纳米器件的非平衡输运；(4) 声子计算——phonopy 接口（Sec. VI.E）可快速生成有限差分简谐/非简谐声子谱；(5) 预筛选——与 GFN1/2-xTB 对比的 S30L 基准（Table I）表明 DFTB3(3ob)+D4 对非共价键合体系可达到实用精度，适合候选材料的大规模初筛。训练和分析系统的 ASE Python 接口（Sec. VI.E）进一步提升了预筛选工作流的自动化程度。问题 2参数集、近似层级和适用域应如何随可视化结果保存？回答： 参数和近似信息对可视化结果的解释至关重要：(1) 参数集标识——DFTB+ 使用 Slater-Koster 参数文件（Sec. II.B），不同参数集（如 mio、3ob 等）描述不同元素组合和化学环境，可视化时必须记录所用参数集名称（例如"DFTB3(3ob)-D3(BJ)"）以避免误解；(2) 近似层级——DFTB1 非自洽（非 SCC）、DFTB2（SCC）、DFTB3（三阶），层级越高精度越高但计算成本也越高，可视化结果应标注层级和是否包含自旋极化（Sec. II.E）；(3) 适用域局限性——参数化拟合针对参考分子结构（键长和角度，Sec. II.B），可视化时需明确标注非键相互作用（dispersion 校正类型，如 D3(BJ)、D4）版本和长程校正（LC）参数（Sec. III.C）；(4) Slater-Koster 文件路径和版本号应作为元数据保存，以便复现可视化。问题 3survey 是否需要区分快速探索图与用于定量结论的高精度图？回答： 是的，DFTB+ 的经验证明这种区分至关重要：(1) 定量误差——DFTB 对反应能、氢键能等仍有显著误差（e.g., S30L 基准中 DFTB3(3ob)+D4 MAD{\textasciitilde}7 kcal/mol, Table I），基于 DFTB+ 的计算结果用于定量图件时必须标注近似层级和预期的误差范围；(2) 场景区分建议——快速探索图（结构预筛选、构象搜索、MD 轨迹热力图）可以采用默认 DFTB3 参数进行快速渲染；定量结论图（能量排序、反应机理、光谱指认）应标注近似层级并建议用 DFT/CC 验证；(3) survey 应分别测量(a)用户对不同精度层级的可视化需求，(b)用户是否希望在可视化中自动标注近似层级和适用域边界，(c)用户对"草稿质量"可视化与"出版质量"可视化可接受的最低精度门槛。阅读后回填对问卷题目的影响：可增加关于"近似层级与参数集自动标注需求"以及"不同精度场景下可视化预期误差标注"的题目可转化为访谈追问：用户是否曾因 DFTB+ 参数选择不当导致误解可视化结果关键证据页码/图表：Sec. II (DFTB1/2/3 层级), Table I (S30L 基准), Sec. II.E (自旋极化), Sec. III.C (LC-DFTB), Sec. IV.B (XLBOMD), Sec. VI.E (ASE/phonopy 接口)仍未解决的问题：DFTB+ 是否支持自动输出近似层级元数据到通用可视化格式？综合摘要本文（Hourahine et al., J. Chem. Phys. 152, 124101, 2020）综述了 DFTB+ 方法体系：从 DFTB1（非 SCC）到 DFTB2（SCC）再到 DFTB3（三阶）的层级化近似（Sec. II），自旋极化扩展（Sec. II.E）、长程校正杂化功能（LC-DFTB，Sec. III.C）、激发态 TD-DFTB（Sec. IV.C）和电子输运 NEGF（Sec. IV.D）。适用大体系（千原子级 MD，Sec. VI.F）和高速预筛选。ASE 和 phonopy 接口（Sec. VI.E）提供了外部工具集成。关键启示：DFTB+ 的结果必须附带参数集标识和近似层级元数据才能正确解释，survey 应区分快速探索和定量结论两种可视化场景。},
	file = {已提交版本:D\:\\Zotero\\storage\\KNLSNU6A\\Hourahine 等 - 2020 - DFTB+, a software package for efficient approximate density functional theory based atomistic simula.pdf:application/pdf},
}

@article{giannozzi_advanced_2017,
	title = {Advanced capabilities for materials modelling with {Q} {\textless}span style="font-variant:small-caps;"{\textgreater}uantum{\textless}/span{\textgreater} {ESPRESSO}},
	volume = {29},
	issn = {0953-8984, 1361-648X},
	url = {https://iopscience.iop.org/article/10.1088/1361-648X/aa8f79},
	doi = {10.1088/1361-648X/aa8f79},
	abstract = {Abstract
            
              Q
              uantum
              ESPRESSO is an integrated suite of open-source computer codes for quantum simulations of materials using state-of-the-art electronic-structure techniques, based on density-functional theory, density-functional perturbation theory, and many-body perturbation theory, within the plane-wave pseudopotential and projector-augmented-wave approaches. Q
              uantum
              ESPRESSO owes its popularity to the wide variety of properties and processes it allows to simulate, to its performance on an increasingly broad array of hardware architectures, and to a community of researchers that rely on its capabilities as a core open-source development platform to implement their ideas. In this paper we describe recent extensions and improvements, covering new methodologies and property calculators, improved parallelization, code modularization, and extended interoperability both within the distribution and with external software.},
	language = {en},
	number = {46},
	journal = {Journal of Physics: Condensed Matter},
	author = {Giannozzi, P and Andreussi, O and Brumme, T and Bunau, O and Buongiorno Nardelli, M and Calandra, M and Car, R and Cavazzoni, C and Ceresoli, D and Cococcioni, M and Colonna, N and Carnimeo, I and Dal Corso, A and De Gironcoli, S and Delugas, P and DiStasio, R A and Ferretti, A and Floris, A and Fratesi, G and Fugallo, G and Gebauer, R and Gerstmann, U and Giustino, F and Gorni, T and Jia, J and Kawamura, M and Ko, H-Y and Kokalj, A and Küçükbenli, E and Lazzeri, M and Marsili, M and Marzari, N and Mauri, F and Nguyen, N L and Nguyen, H-V and Otero-de-la-Roza, A and Paulatto, L and Poncé, S and Rocca, D and Sabatini, R and Santra, B and Schlipf, M and Seitsonen, A P and Smogunov, A and Timrov, I and Thonhauser, T and Umari, P and Vast, N and Wu, X and Baroni, S},
	month = nov,
	year = {2017},
	pages = {465901},
	annote = {Survey 定向阅读问题关联模块： Quantum ESPRESSO 与材料可视化阅读时请直接在每个"回答"后补充结论，并记录对应页码、图表或原文位置。阅读问题问题 1Quantum ESPRESSO 的哪些材料建模能力直接产生电荷密度、势、能带或费米面数据？回答： QE 产生可直接可视化的数据包括：(1) 电荷密度和自旋密度——PWscf 和 CP 计算输出 File per 格式，通过 pp.x 可导出为多种格式（Sec. III.C）；(2) 势能面——通过 PWscf 的 SCF 总能计算和 phonon 模块的线性响应（PHonon, Sec. II.D）；(3) 能带结构——bands.x 后处理工具，结合 PWscf 的 KS 本征值输出（Sec. II.A 杂化泛函）；(4) 费米面——通过 MLWFs 最大局域化 Wannier 函数插值（Sec. III.D）；(5) 静电势和平均静电势——pp.x 计算，用于功函数和能带对齐分析；(6) 态密度（DOS）和投影态密度（PDOS）——dos.x 和 projwfc.x 后处理 (Sec. III.C)；(7) X 射线吸收谱（XSpectra, Sec. II.F.2）和 NMR/EPR 参数（GIPAW, Sec. II.F.1）对应的跃迁密度；(8) 电子-声子耦合矩阵元——EPW 模块（Sec. II.D.3）基于 Wannier 插值；(9) 实时 TDDFT（turboTDDFT, Sec. II.E）产生的时变偶极矩和吸收谱。问题 2用户实际交换的原生文件和通用格式分别有哪些？回答： QE 的文件生态如下：(1) 原生格式——XML 文件（含 schema，Sec. III.C.1）基于 Fortran 二进制或文本格式存储波函数和电荷密度；大型记录数据文件格式（Sec. III.C.2）Fortran 直接访问格式；(2) HDF5 格式支持（Sec. III.C）——作为结构化记录格式，支持跨架构可移植性；(3) 后处理导出——pp.x 可将电荷密度/势转换为通用格式（XSF、GOpenMol、CUBE 等）；(4) AiiDA（Sec. III.E.1）Python 材料信息学基础设施，自动记录计算流程和 I/O 文件之间的溯源关系；pwtk（Sec. III.E.2）简化 PWscf 工作流的工具包；(5) 用户常用交换路径：pp.x→XSF/CUBE 用于 VESTA/XCrySDen/VMD 可视化；XML 文件用于程序间交换；HDF5 用于大规模数据传输。问题 3周期晶格、k 点、自旋和赝势信息中哪些是可复核图像的最低元数据？回答： 可复核 QE 可视化图像的最低元数据应包含：(1) 晶格参数——晶胞矢量、晶系/空间群（Sec. II.C.2, III.C）；(2) k 点网格——Monkhorst-Pack 或 Γ-centered 网格大小及偏移；(3) 动能截断（ecutwfc, ecutrho）和赝势类型（Ultrasoft/PAW/Norm-conserving）及元素-赝势文件映射（Sec. I）；(4) 自旋——是否自旋极化、非共线磁化或 SOC（Sec. II.C.5）；(5) 泛函——交换-相关泛函（LDA/GGA/杂化/DFT+U/DFT+D，Sec. II.A）；(6) 后处理参数——等值面值和等值面类型（如电荷密度 vs 自旋密度 vs 静电势）。最低要求建议：晶胞矢量 + 原子坐标 + 泛函 + 赝势 + k 点 + 截断能。阅读后回填对问卷题目的影响：可增加关于"HDF5/XML 标准格式的采用意愿"和"最低可视化元数据需求"的题目可转化为访谈追问：用户使用 pp.x 后处理的工作流细节及其与可视化工具的集成体验关键证据页码/图表：Sec. I (开源哲学), Sec. III.C (XML/HDF5 格式), Sec. III.E (AiiDA/pwtk), Sec. II.A (杂化泛函), Sec. II.D (声子/EPW), Sec. II.E (turboTDDFT), Sec. II.F (XSpectra/GIPAW)仍未解决的问题：HDF5 支持和 XML schema 是否完全覆盖所有数据类型？综合摘要本文（Giannozzi et al., J. Phys.: Condens. Matter 29, 465901, 2017）综述了 QE 在 v6.2 之前的新能力：方法学上涵盖杂化泛函、DFT+U+vW、实时 TDDFT（turboTDDFT）、GW/BSE（Sec. II.E）、电子-声子耦合（EPW, Sec. II.D.3）和磁共振（GIPAW, Sec. II.F）。技术架构上引入可选的 HDF5 格式（Sec. III.C）、XML schema 标准化输出、AiiDA 工作流管理（Sec. III.E.1）和 pwtk 脚本化（Sec. III.E.2）。可视化生态以 pp.x→XSF/CUBE 为核心路线，PostProc 套件完成数据处理。最低可视化元数据要求包括晶格参数、k 点网格、赝势定义、泛函选择和截断能。},
	file = {已提交版本:D\:\\Zotero\\storage\\8IJA2Q8Y\\Giannozzi 等 - 2017 - Advanced capabilities for materials modelling with Q uantum.pdf:application/pdf},
}

@article{giannozzi_q_2020,
	title = {Q {\textless}span style="font-variant:small-caps;"{\textgreater}uantum{\textless}/span{\textgreater} {ESPRESSO} toward the exascale},
	volume = {152},
	issn = {0021-9606, 1089-7690},
	url = {https://pubs.aip.org/jcp/article/152/15/154105/1058748/Quantum-ESPRESSO-toward-the-exascale},
	doi = {10.1063/5.0005082},
	abstract = {Quantum ESPRESSO is an open-source distribution of computer codes for quantum-mechanical materials modeling, based on density-functional theory, pseudopotentials, and plane waves, and renowned for its performance on a wide range of hardware architectures, from laptops to massively parallel computers, as well as for the breadth of its applications. In this paper, we present a motivation and brief review of the ongoing effort to port Quantum ESPRESSO onto heterogeneous architectures based on hardware accelerators, which will overcome the energy constraints that are currently hindering the way toward exascale computing.},
	language = {en},
	number = {15},
	journal = {The Journal of Chemical Physics},
	author = {Giannozzi, Paolo and Baseggio, Oscar and Bonfà, Pietro and Brunato, Davide and Car, Roberto and Carnimeo, Ivan and Cavazzoni, Carlo and De Gironcoli, Stefano and Delugas, Pietro and Ferrari Ruffino, Fabrizio and Ferretti, Andrea and Marzari, Nicola and Timrov, Iurii and Urru, Andrea and Baroni, Stefano},
	month = apr,
	year = {2020},
	pages = {154105},
	annote = {Survey 定向阅读问题关联模块： Exascale、并行 I/O 与部署阅读时请直接在每个"回答"后补充结论，并记录对应页码、图表或原文位置。阅读问题问题 1迈向 exascale 后，计算、I/O、数据移动和后处理哪个环节最限制可视化？回答： 基于本文对 QE 在异构架构（GPU 加速器）上移植的分析，各环节限制程度如下：(1) 数据移动和内存管理是最主要瓶颈——异构内存管理、宿主机与加速器间的数据搬移开销（Sec. I, Sec. III），特别是 GPU 显存容量（当前 GPU 显存从数十 GB 到数百 GB）限制了实时波函数和电荷密度的驻留；(2) I/O 环节是第二限制因素——尽管 XML schema 和 HDF5（Sec. II）结构化 I/O 已缓解部分问题，但 exascale 规模下大量节点并发 I/O 仍面临 POSIX 文件系统的竞争冲突（Sec. I）；(3) 后处理（Post-processing）限制来自于数据量本身——百万原子级模拟产生的电荷密度文件可达数 TB，传统单机后处理工具难以加载；(4) 计算本身（offload 到 GPU）由于采用了 GPU 加速，反而是最不限制的环节。综上，数据移动 {\textgreater} I/O {\textgreater} 后处理 {\textgreater} 计算。问题 2引擎无关工具需要在计算节点、登录节点还是本地工作站运行？回答： 基于 QE exascale 部署架构，建议分层部署：(1) 计算节点——适合运行轻量级 in-situ 可视化插件（直接读取 GPU 内存中的电荷密度数据，避免 I/O），但受限于计算节点上的软件环境（通常无 GPU 图形驱动）和内存竞争；(2) 登录节点——适合运行 HDF5 到通用格式的离线转换工具（如 QE 的 pp.x 后处理），但登录节点通常共享资源，大规模并行后处理不可行；(3) 本地工作站——最适合交互式可视化，通过小规模 HDF5/XML 文件或下采样后的网格数据进行。对于 exascale 规模的 QE 模拟，引擎无关工具应以"登录节点转换 → 本地工作站可视化"为主要模式，同时探索 in-situ（计算节点内）轻量渲染的可能性。问题 3问卷应如何测量并行文件系统、离线环境和大数据下采样需求？回答： 基于 QE exascale 经验，建议问卷测量以下维度：(1) 并行 I/O 需求——询问用户当前使用的文件系统类型（Lustre/GPFS/其他）和典型输出文件大小，以及 HDF5 格式的使用频率和满意度（Sec. II）；(2) 离线环境——测量用户在无网络的计算集群上完成可视化的比例，以及 scp/rsync 数据传送时间的占比；(3) 下采样需求——测量用户对直接渲染全分辨率数据 vs 使用 downsampled/coarse-grained 网格的偏好，以及需要保留的元数据粒度（原子坐标、晶胞参数、等值面值）；(4) 工具部署偏好——测量用户是否愿意将可视化工具部署为 Python 库（如 AiiDA 模式，Sec. II）或独立 GUI 应用。阅读后回填对问卷题目的影响：可增加关于"HDF5 格式采用率"、"exascale 数据下采样需求"和"in-situ vs post-hoc 可视化偏好"的题目可转化为访谈追问：用户在大规模 QE 模拟中遇到 I/O 瓶颈的具体场景关键证据页码/图表：Sec. I (异构架构与数据移动瓶颈), Sec. II (XML/HDF5 结构 I/O), Sec. III (GPU 加速器 porting 策略与性能分析), Sec. IV (结论)仍未解决的问题：QE 是否有正式的 in-situ 可视化接口计划？综合摘要本文（Giannozzi et al., J. Chem. Phys. 152, 154105, 2020）描述了 QE 向 exascale 异构架构移植的进展。核心挑战是数据移动（GPU 显存与宿主内存间）而非计算本身。结构 I/O（XML + 可选 HDF5）已部分缓解传统 POSIX I/O 瓶颈，但 exascale 规模下的后处理和可视化仍受限于数据体量（TB 级电荷密度文件）。建议的可视化路径为"登录节点转换 → 本地工作站渲染"，同时探索 in-situ 轻量渲染。问卷应测量 HDF5 采用率、下采样需求和离线环境部署偏好。},
	file = {已提交版本:D\:\\Zotero\\storage\\GHJLRQ23\\Giannozzi 等 - 2020 - Q uantum ESPRESSO toward the exascale.pdf:application/pdf},
}

@article{kresse_efficient_1996,
	title = {Efficient iterative schemes for \textit{ab initio} total-energy calculations using a plane-wave basis set},
	volume = {54},
	issn = {0163-1829, 1095-3795},
	url = {https://link.aps.org/doi/10.1103/PhysRevB.54.11169},
	doi = {10.1103/PhysRevB.54.11169},
	language = {en},
	number = {16},
	journal = {Physical Review B},
	author = {Kresse, G. and Furthmüller, J.},
	month = oct,
	year = {1996},
	pages = {11169--11186},
	annote = {Survey 定向阅读问题关联模块： VASP/平面波收敛与性能阅读时请直接在每个"回答"后补充结论，并记录对应页码、图表或原文位置。阅读问题问题 1平面波总能计算的迭代、混合和预条件设置如何影响收敛与结果可信度？回答： 本文的核心贡献即回答了此问题：(1) 迭代对角化——Pulay DIIS（直接反演迭代子空间）方法（Sec. II）用于大矩阵迭代对角化，稳定可靠，最小化 O(N\_atoms{\textasciicircum}3) 操作次数；(2) 电荷密度混合——基于 Pulay 方案的混合方法（Sec. III），引入优化的"度规"（metric）和"预条件"（preconditioning），使迭代次数几乎与体系规模无关；(3) 预条件——平面波基组的特殊预条件对收敛速度至关重要（Sec. III Eq. 23-25），错误的预条件会导致收敛缓慢或振荡；(4) 收敛阈值和基组截断能（ecut）必须同时满足，本文发现 O(N\_atoms{\textasciicircum}2) 标度适用于最多 1000 电子的体系（Sec. IV, Table II）；(5) 有限温度 smearing（Sec. II, Eq. 4）对金属体系收敛至关重要，filling 参数影响最终能量精度。这些参数的选择直接影响结果的可信度，可视化用户需要了解至少使用的截断能和 k 点网格。问题 2体系规模、k 点和精度之间的性能关系应如何解释，避免把程序品牌当作速度结论？回答： 本文清晰地建立了这种关系而非依赖品牌：(1) O(N\_atoms{\textasciicircum}2) 标度——对于非自洽计算，操作次数 {\textasciitilde} N\_atoms × N\_bands ≈ O(N\_atoms{\textasciicircum}2)（Sec. IV, Table I）；(2) k 点密度——k 点数 ∝ 1/体系体积，对于大体系 k 点可线性减少（Sec. IV），总标度接近 O(N\_atoms)；(3) 内存需求——电荷密度混合法不要求显式存储所有波函数（Sec. III.A），内存开销与体系大小成亚线性关系；(4) 性能分析具体给出了 CPU 时间与体系大小的表格（Table I：20-100 原子 Si 体系）和图表（Figure 2: 收敛曲线），验证了方法的可扩展性；(5) 解释建议——应引用本文学术的标度分析而非"VASP 就是快"式的模糊表述。问题 3VASP 原生体数据适配时需要保存哪些收敛、晶胞和网格信息？回答： 基于本文方法，VASP 体数据适配需保存：(1) 晶胞信息——平面波基组定义的关键：截断能（ecut, Ry 或 eV 单位）、晶胞矢量、倒格矢（Sec. II）；(2) k 点网格——Monkhorst-Pack 或 Γ-centered 网格大小和偏移量，以及使用的 smearing 类型和展宽（Sec. II Eq. 4）；(3) 收敛信息——最后 SCF 循环的能量差和电荷密度残差（Eq. 19），用于判断结果是否充分收敛；(4) 混合参数——混合方法（Kerker/Pulay）和参数（AMIX、BMIX），不同的混合参数影响收敛行为，是诊断收敛问题的关键元数据；(5) 基组大小——平面波数量（N\_PW）和网格点数（FFT grid），直接影响电荷密度/势场的空间分辨率，是可视化网格的必要元数据；(6) 类型——自旋极化/非极化/非共线磁化设置。阅读后回填对问卷题目的影响：可增加关于"平面波计算收敛参数元数据保存需求"和"用户对收敛标准的理解程度"的题目可转化为访谈追问：VASP 用户如何判断计算是否收敛，以及可视化时是否关注收敛信息关键证据页码/图表：Sec. II (DIIS 迭代), Sec. III (混合方法与预条件), Table I (标度数据), Table II (1000 电子体系性能), Figure 2 (收敛曲线)仍未解决的问题：本文为 1996 年方法论文，未涉及 VASP 现代输出格式（XML、HDF5），需结合 VASP 新版手册补充格式细节综合摘要本文（Kresse \& Furthmüller, Phys. Rev. B 54, 11169, 1996）提出了 VASP 核心的迭代求解方案：Pulay DIIS 迭代对角化（Sec. II）加速本征值收敛，基于 Pulay 的电荷密度混合方法（Sec. III）引入优化的平面波度规和预条件，使 SCF 收敛步数几乎独立于体系大小。标度分析（Sec. IV）证明了 O(N{\textasciicircum}2) 到 O(N) 的可扩展性（最大 1000 电子）。对于可视化而言，截断能（ecut）、k 点网格和 FFT 网格分辨率是重建 VASP 体数据（电荷密度、静电势）的最低必要元数据，混合参数和收敛残差是诊断可视化质量的关键辅助信息。},
	file = {全文:D\:\\Zotero\\storage\\BFUFJN5A\\Kresse和Furthmüller - 1996 - Efficient iterative schemes for ab initio total-energy calculations using a plane-wave basis.pdf:application/pdf},
}

@article{blum_ab_2009,
	title = {Ab initio molecular simulations with numeric atom-centered orbitals},
	volume = {180},
	issn = {00104655},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S0010465509002033},
	doi = {10.1016/j.cpc.2009.06.022},
	language = {en},
	number = {11},
	journal = {Computer Physics Communications},
	author = {Blum, Volker and Gehrke, Ralf and Hanke, Felix and Havu, Paula and Havu, Ville and Ren, Xinguo and Reuter, Karsten and Scheffler, Matthias},
	month = nov,
	year = {2009},
	pages = {2175--2196},
	annote = {Survey 定向阅读问题关联模块： FHI-aims、数值原子轨道与跨表示阅读时请直接在每个"回答"后补充结论，并记录对应页码、图表或原文位置。阅读问题问题 1数值原子轨道表示与高斯/平面波表示在场重建和网格输出上有何差异？回答： FHI-aims 使用数值原子轨道（NAO, numerically tabulated atom-centered orbitals, Sec. 1）作为基组，与高斯/平面波表示存在本质差异：(1) 基组形式——NAO 是预先数值化的径向函数 × 球谐函数，不依赖于解析高斯指数，基函数由截断半径内的数值网格点定义（Sec. 2.1），而高斯基组有解析表达式；平面波则用倒空间基；(2) 场重建——FHI-aims 用实空间网格（均匀 FFT 或自适应的多样化网格，Sec. 2.3）来构筑密度和势，所有 grid-based 操作标度 O(N)（Sec. 2.4），而平面波法依靠 FFT 在倒空间操作；(3) 网格输出——NAO 的密度通过投影到实空间网格上输出，直接产生真实空间网格格式（cube 或类似格式），但本文未明确说明输出格式；(4) 全电子（all-electron）/全势（full-potential）处理（Sec. 1），NAO 没有赝势近似或 PAW 变换，因此电荷密度在核区域有完整振荡结构，可视化时需要更密集的网格来捕捉核区域特征。问题 2不同精度层级和基函数设置怎样影响跨程序对照？回答： FHI-aims 提供层级化基组（"light"/"tight"/"really tight"/"very tight", Sec. 5.1），直接影响跨程序对照：(1) 基组收敛性——NAO 基组可通过增加径向基函数数量（每个原子的 spd-f-g 层次）逐步逼近完备基组极限（CBS），表 3 展示不同层级下的总能量收敛行为；(2) 跨程序差异——FHI-aims 的全电子 NAO 结果与平面波计算（VASP/PWscf）的系统性差异主要来自：(a) 基组完备性差异，(b) PAW 投影近似 vs 全电子，(c) NAO 的截断半径近似 vs 平面波的无截断傅立叶表示；(3) 性能方面，NAO 的标度 O(N)（Sec. 2.4）相比平面波的 O(N{\textasciicircum}3) 逐 FFT 方法对大体系有利，但 NAO 基组缺乏标准化的完备性指标使得跨程序系统偏差难以预估；(4) 建议——跨程序对照时，应同时使用 FHI-aims 的 tight 以上基组和 VASP 的高截断能设置。问题 3FHI-aims 用户需要哪些材料、周期和全电子可视化功能？回答： 基于 FHI-aims 的特性，用户的可视化需求包括：(1) 全电子电荷密度——核区域 oscillatory 结构的精细等值面（all-electron cusp），需要比赝势/PAW 方法更密的网格分辨率；(2) 静电势和 Ehrenfest 力——全势方法直接计算全电子静电势（Sec. 3.5），用于静电势映射和功函数分析；(3) 自旋密度——自旋极化的 NAO 计算输出自旋密度，可用于磁性材料可视化（Sec. 3.4）；(4) 周期体系能带/Bloch 态——FHI-aims 支持周期性边界条件（Sec. 4.2），需要能带结构和部分电荷密度可视化；(5) GW/BSE 准粒子能级和跃迁密度（Sec. 3.6, 3.7）——对应激发态可视化；(6) 分子动力学轨迹——FHI-aims MD（Eq. 80）需要轨迹动画可视化；(7) 基函数可视化——NAO 的数值形式本身可能被可视化（径向函数的截断半径和形状）。目前 FHI-aims 原生输出格式未明确定义为 cube/Molden，可能需要独立的后处理步骤。阅读后回填对问卷题目的影响：可增加关于"全电子 vs 赝势对可视化网格分辨率需求差异"和"NAO 基组对应基函数可视化需求"的题目可转化为访谈追问：FHI-aims 用户目前使用哪些工具进行全电子电荷密度可视化关键证据页码/图表：Sec. 2.1 (NAO 基组), Sec. 2.4 (O(N) 网格算法), Sec. 3.4 (自旋), Sec. 3.5 (静电势), Sec. 4.2 (周期), Sec. 5.1 and Table 3 (基组收敛), Equation 80 (MD)仍未解决的问题：FHI-aims 是否自动输出 cube 格式，还是用户需要后处理转换？综合摘要本文（Blum et al., Comput. Phys. Commun. 180, 2175-2196, 2009）系统描述了 FHI-aims 的 NAO 全电子全势方法：数值化原子中心轨道（Sec. 2.1）、层级化基组（Sec. 5.1）、O(N) 实空间网格算法（Sec. 2.4-2.5）和所有-electron 全势处理（无赝势）。方法涵盖 DFT（GGA）、杂化泛函（Sec. 3.1）、GW 准粒子（Sec. 3.6）、RPA（Sec. 3.7）和 MD（Sec. 4.1）。与平面波 vs NAO 跨程序对照的关键差异在于基组完备性的可比较性、全电子 vs PAW 对近核区域处理的不同。可视化方面需要全电子密度的高分辨率网格、周期材料的能带/费米面和激发态跃迁密度。},
	file = {全文:D\:\\Zotero\\storage\\WM4BC2BI\\Blum 等 - 2009 - Ab initio molecular simulations with numeric atom-centered orbitals.pdf:application/pdf},
}

@article{bannwarth_gfn2-xtbaccurate_2019,
	title = {{GFN2}-{xTB}—{An} {Accurate} and {Broadly} {Parametrized} {Self}-{Consistent} {Tight}-{Binding} {Quantum} {Chemical} {Method} with {Multipole} {Electrostatics} and {Density}-{Dependent} {Dispersion} {Contributions}},
	volume = {15},
	issn = {1549-9618, 1549-9626},
	url = {https://pubs.acs.org/doi/10.1021/acs.jctc.8b01176},
	doi = {10.1021/acs.jctc.8b01176},
	language = {en},
	number = {3},
	journal = {Journal of Chemical Theory and Computation},
	author = {Bannwarth, Christoph and Ehlert, Sebastian and Grimme, Stefan},
	month = mar,
	year = {2019},
	pages = {1652--1671},
	annote = {Survey 定向阅读问题关联模块： xTB、快速探索与适用域阅读时请直接在每个"回答"后补充结论，并记录对应页码、图表或原文位置。阅读问题问题 1GFN2-xTB 主要为哪些规模和性质设计，其参数适用域边界是什么？回答： GFN2-xTB 的设计目标和适用域：(1) 规模——适用于大分子体系（数百到数千原子），无需专门硬件（Sec. 1），参数化至 Rn（Z=86），覆盖周期表大部分元素；(2) 目标性质——结构优化（几何参数）、振动频率、非共价相互作用、偶极矩、旋转常数（Sec. 3, Table 1）；(3) 适用域边界——"On-target"性质和"Off-target"性质（barrier heights, dipole moments, 除目标分子结构/非共价/NMR 外的其他性质）在 S30L 基准上 MAD 达到约 1.5-2 kcal/mol（Figure 4）；(4) 方法学边界——GFN2-xTB 在 DLPNO-CCSD(T)/CBS 参考上的偏差（Table 4）提示其对氢键和静电主导的相互作用最准确，对色散主导较差的局限性；(5) 跨元素适用域——目前参数化至 Rn（Z=86），超重元素不可用。用户应注意 GFN2-xTB 并非适用于所有体系，特别是含强相关效应的体系。问题 2快速结构/非共价计算结果适合哪些可视化决策，不适合支持哪些定量结论？回答： 基于 GFN2-xTB 的精度特征：(1) 适合的可视化决策——(a) 构象搜索/CREST 采样轨迹的热图展示（conformer-rotamer ensemble generation, Figure 7），(b) 非共价相互作用区域识别（NCI 分析），(c) 大分子的预筛选结构比较，(d) 振动模式动画展示（频率计算），(e) 反应物/产物构象变化的定性展示；(2) 不适合支持的定量结论——(a) 反应能垒的精确数值（off-target barrier heights 误差较大），(b) 结合自由能数值呈现（GFN2-xTB 不包括溶剂和熵的所有贡献），(c) 高精度能量排序（Miller 指数/晶型选择），(d) 光谱跃迁能量的精确值（除非结合适当的基准校正）；(3) 可视化中必须标注该计算使用的 xTB 参数版本和 D4 色散校正设置（Table 2, 3），以便评估定量结论的可靠性。问题 3用户是否需要在同一工作流中从 xTB 预筛选切换到 DFT 并保持场景可追溯？回答： 是的，这恰恰是 GFN2-xTB 的典型使用模式：(1) 双层工作流——xTB 预筛选（构象生成、粗略势能面扫描）→ DFT/CC 精修（精确能量和性质），这是常见的策略（Sec. 3, Sec. 4）；(2) CREST（conformer-rotamer ensemble sampling）→ 高精度单点计算的工作流已被多个案例采用（Figure 7, NMR 谱预测）；(3) 可追溯性需求——可视化工具应保留各层级计算的溯源信息：初始 xTB 构象、参数版本、D4 设置、后续 DFT 计算的功能和基组；(4) 场景建议——survey 应测量用户是否希望在可视化中看到"预筛选→精修"两阶段标注（例如，半透明预筛选渲染 + 彩色定量标注），以及用户是否需要一个自动记录多层计算参数的工作流管理器。阅读后回填对问卷题目的影响：可增加关于"多层精度工作流可视化标注需求"和"xTB→DFT 切换的可追溯性要求"的题目可转化为访谈追问：用户使用 GFN2-xTB 预筛选后通常用哪个软件做 DFT 精修以及如何管理数据关键证据页码/图表：Sec. 1 (设计理念), Table 1-4 (基准测试), Figure 4 (S30L 误差), Figure 6 (GMTKN55), Figure 7 (CREST 构象), Sec. 4 (结论)仍未解决的问题：GFN2-xTB 的原生输出是否包含足够的元数据以支持自动化预筛选标注？综合摘要本文（Bannwarth et al., J. Chem. Theory Comput. 15, 1652-1671, 2019）提出了 GFN2-xTB 方案，一个扩展的紧束缚模型，特色是多级静电（Mulliken + 多极）和依赖于电子密度的 D4 色散校正。参数化至 Rn（Z=86），目标性质为结构参数、振动频率、非共价相互作用。在 S30L 和 GMTKN55 基准上 MAD {\textasciitilde}1.5-2 kcal/mol。xTB 的典型工作流是"预筛选（CREST/xTB）→ 精修（DFT/CC）"双层模式，可视化工具应支持这种跨越精度层级的场景可追溯性。快速探索图与定量结论图的区分至关重要，图层应标注 xTB 参数版本和 D4 设置。},
	file = {全文:D\:\\Zotero\\storage\\TVN2UIGT\\Bannwarth 等 - 2019 - GFN2-xTB—An Accurate and Broadly Parametrized Self-Consistent Tight-Binding Quantum Chemical Method.pdf:application/pdf},
}

@article{williamsyoung_chronus_2020,
	title = {The {Chronus} {Quantum} software package},
	volume = {10},
	issn = {1759-0876, 1759-0884},
	url = {https://wires.onlinelibrary.wiley.com/doi/10.1002/wcms.1436},
	doi = {10.1002/wcms.1436},
	abstract = {Abstract
            The Chronus Quantum (ChronusQ) software package is an open source (under the GNU General Public License v2) software infrastructure which targets the solution of challenging problems that arise in ab initio electronic structure theory. Special emphasis is placed on the consistent treatment of time dependence and spin in the electronic wave function, as well as the inclusion of relativistic effects in said treatments. In addition, ChronusQ provides support for the inclusion of uniform finite magnetic fields as external perturbations through the use of gauge‐including atomic orbitals. ChronusQ is a parallel electronic structure code written in modern C++ which utilizes both message passing implementation and shared memory (OpenMP) parallelism. In addition to the examination of the current state of code base itself, a discussion regarding ongoing developments and developer contributions will also be provided.
            
              This article is categorized under:
              
                
                  Software {\textgreater} Quantum Chemistry
                
                
                  Electronic Structure Theory {\textgreater} Ab Initio Electronic Structure Methods
                
                
                  Electronic Structure Theory {\textgreater} Density Functional Theory},
	language = {en},
	number = {2},
	journal = {WIREs Computational Molecular Science},
	author = {Williams‐Young, David B. and Petrone, Alessio and Sun, Shichao and Stetina, Torin F. and Lestrange, Patrick and Hoyer, Chad E. and Nascimento, Daniel R. and Koulias, Lauren and Wildman, Andrew and Kasper, Joseph and Goings, Joshua J. and Ding, Feizhi and DePrince, A. Eugene and Valeev, Edward F. and Li, Xiaosong},
	month = mar,
	year = {2020},
	pages = {e1436},
	annote = {Survey 定向阅读问题关联模块： Chronus Quantum、响应与相对论性质阅读时请直接在每个"回答"后补充结论，并记录对应页码、图表或原文位置。阅读问题问题 1Chronus Quantum 的特色方法会产生哪些自旋、时域、响应或相对论可视化对象？回答： ChronusQ 的核心特色（摘要，Sec. 1）产生独特的可视化对象：(1) 自旋——时间依赖的自旋密度演化（RT-TDDFT），非共线自旋结构，自旋极化矢量场（Sec. 2, Sec. 4）；(2) 时域——实时传播的电荷密度和偶极矩随时间演化的可视化（RT-TDDFT, Sec. 4.2），包括电场脉冲激发的时域响应；(3) 响应——含频（频率域）响应性质，包括极化率、超极化率张量的可视化（Sec. 4.3）；(4) 相对论——自旋-轨道耦合（SOC）影响下的电子结构和旋量波函数（Sec. 3），有限磁场下的 GIAO 轨道表示（Sec. 5）；(5) 线性响应——吸收光谱、旋光色散（ORD）和圆二色（ECD）谱图的激发态可视化；(6) 非绝热耦合——势能面锥形交叉区域的自旋-轨道耦合向量。问题 2这些高级对象是否能用现有 Cube/Molden 表达，还是需要结构化数据模型？回答： (1) Cube/Molden 可部分表达——标准 Cube 可存储静态自旋密度和电荷密度，Molden 可存储分子轨道系数，足以表达大多数 DFT/HF 结果的基本可视化对象；(2) 需要结构化数据模型的对象——(a) 自旋密度随时间演化的 3D+Time 数据集（RT-TDDFT 4D 数据）需要 HDF5 或 NetCDF 等多帧格式；(b) 含频极化率张量（3x3 频域矩阵）需要以 JSON/XML 等结构化格式存储频率依赖关系；(c) 旋量波函数（相对论二分量/四分量）的非共线磁化方向矢量在每个实空间点需要额外的矢量字段；(d) GIAO 的轨道磁场展宽需要轨道-磁场耦合元数据；(e) 多个耦合激发态之间的跃迁密度矩阵（TDDFT 响应）需要矩阵格式。结论：静态电荷密度/自旋密度可用 Cube 表达，但 RT-TDDFT、相对论和含频响应数据需要类似 HDF5 的层次化结构化数据模型。问题 3潜在用户群是否足以在问卷中单独测量，还是适合作为开放题案例？回答： (1) ChronusQ 是较新的开源代码（GPL v2, 摘要），专注于特定领域（时间依赖、自旋、相对论、磁场），用户群相对较小但极具特色；(2) 建议测量方式——在问卷中作为"其他常用软件"的开放选项的一部分，而非单独列出独立模块；(3) 开放题价值——ChronusQ 用户的特殊需求（RT-TDDFT 时域可视化、旋量波函数、GIAO 磁场响应）可为可视化工具提供前沿用例，也为 Cube/Molden 格式扩展需求提供实证；(4) 如果 survey 发现多名 ChronusQ 用户，可考虑在后续深入访谈中专门设置一组关于"TDDFT 实时传播可视化"的追问。总体建议：问卷设一道开放题"列出您使用的其他量子化学软件"，将 ChronusQ 出现的频率作为衡量该群体规模的代理指标。阅读后回填对问卷题目的影响：可增补关于"时域/频域响应数据可视化需求"的开放题可转化为访谈追问：ChronusQ 用户如何可视化自旋动力学和非共线磁性结构关键证据页码/图表：摘要 (GPL v2, RT-TDDFT, GIAO), Sec. 1 (时间与自旋一致处理), Sec. 3 (相对论), Sec. 4.2 (RT-TDDFT), Sec. 4.3 (响应理论), Sec. 5 (磁场/GIAO)仍未解决的问题：ChronusQ 是否有计划支持 HDF5 或 VTK 格式以存储 4D 时域数据？综合摘要本文（Williams-Young et al., WIREs Comput. Mol. Sci. 10, e1436, 2020）介绍了 ChronusQ 开源（GPL v2）量子化学软件包，专注于时间依赖、自旋一致处理和相对论效应。核心方法包括：RT-TDDFT 实时传播（Sec. 4.2）、含频响应理论（Sec. 4.3）、相对论二分量/四分量方法（Sec. 3）、有限磁场 GIAO（Sec. 5）、非绝热耦合 SOC（Sec. 4.5）。可视化需求超越传统 Cube/Molden 格式：RT-TDDFT 产生 4D（3D+Time）自旋/电荷密度流、旋量波函数需要矢量场数据、含频响应需要频域张量存储。建议在问卷中通过开放题测量 ChronusQ 用户群规模。},
	file = {已提交版本:D\:\\Zotero\\storage\\R54B42B4\\Williams‐Young 等 - 2020 - The Chronus Quantum software package.pdf:application/pdf},
}

@article{mironov_openqp_2024,
	title = {{OpenQP}: {A} {Quantum} {Chemical} {Platform} {Featuring} {MRSF}-{TDDFT} with an {Emphasis} on {Open}-{Source} {Ecosystem}},
	volume = {20},
	issn = {1549-9618, 1549-9626},
	shorttitle = {{OpenQP}},
	url = {https://pubs.acs.org/doi/10.1021/acs.jctc.4c01117},
	doi = {10.1021/acs.jctc.4c01117},
	language = {en},
	number = {21},
	journal = {Journal of Chemical Theory and Computation},
	author = {Mironov, Vladimir and Komarov, Konstantin and Li, Jingbai and Gerasimov, Igor and Nakata, Hiroya and Mazaherifar, Mohsen and Ishimura, Kazuya and Park, Woojin and Lashkaripour, Alireza and Oh, Minseok and Huix-Rotllant, Miquel and Lee, Seunghoon and Choi, Cheol Ho},
	month = nov,
	year = {2024},
	pages = {9464--9477},
	annote = {Survey 定向阅读问题关联模块： OpenQP、激发态与开放互操作阅读时请直接在每个"回答"后补充结论，并记录对应页码、图表或原文位置。阅读问题问题 1MRSF-TDDFT 的结果最需要哪些态、轨道和跃迁可视化？回答： MRSF-TDDFT（Mixed-Reference Spin-Flip TDDFT, Sec. 2.2）是 OpenQP 的标志性方法，产生的可视化需求包括：(1) 旋翻激发态（spin-flip excited states）——常规 TDDFT 无法处理的 open-shell 单重态-三重态混合激发，需要展示自旋翻转前后的自旋密度变化；(2) 跃迁轨道对（natural transition orbitals, NTOs）——MRSF-TDDFT 的跃迁密度矩阵经奇异值分解后产生的主要粒子-空穴对轨道可视化（Sec. 2.2）；(3) DTCAM 系列交换-相关泛函（VAEE, XI, XIV, AEE, VEE, Sec. 2.3）产生的特异性轨道能量和空间分布差异；(4) 双激发（double excitation）特征——MRSF-TDDFT 能描述含有双激发成分的激发态，其跃迁密度的多元可视化需求超越传统 TDDFT；(5) 激发态能量和振子强度——吸收光谱模拟（Figure 4-5, 7-10）需要谱线归属和各激发态的跃迁密度可视化；(6) 锥形交叉区——MRSF-TDDFT 的解析梯度支持 conical intersection 搜索（PyOQP, Sec. 2.4），需要双态之间的轨道和密度差可视化。问题 2自主模块与第三方互联如何体现，适配器能力边界是否可机器读取？回答： OpenQP 采用模块化架构（Sec. 2.1），以"open-source ecosystem"模式（如 PySCF, Psi4 传统，Sec. 1）实现：(1) 自主模块——OpenQP 将 HF、DFT、TDDFT、SF-TDDFT、MRSF-TDDFT 各方法实现为独立模块（oqp.set\_basis, oqp.scf, oqp.tddft 等），模块间通过结构化数据（"mol"类型）连接（Sec. 2.1, Figure 1）；(2) 第三方互联——C API 接口（Sec. 2.1）实现数据交换，允许第三方软件调用特定模块；PyOQP Python 封装（Sec. 2.4）提供几何优化、锥形交叉搜索和非绝热耦合计算；(3) 适配器边界——当前接口能力限制：(a) 不支持自动数据格式转换（如直接输出 Molden/Cube）；(b) 未提供通用的文件 I/O 标准，数据交换依赖 C API 结构体内的数据指针；(c) 尚未与 ASE 等外部环境直接集成；(4) 机器可读能力——结构化数据类型的定义使得模块签名（输入/输出类型）可由程序检查，但跨程序适配器的能力描述尚未标准化（无 schema 或 OpenAPI 式的规范）。问题 3Python 包装、高性能并行和开源生态分别解决哪些采用障碍？回答： OpenQP 的策略覆盖三个不同的障碍层：(1) Python 包装（PyOQP, Sec. 2.4）——解决可用性障碍：自动处理几何优化和锥形交叉搜索，降低输入编写门槛；利用 Python 生态（NumPy, SciPy）进行后处理，降低数据分析门槛；提供与 PySCF 类似的用户体验（Sec. 1），降低学习曲线；(2) 高性能并行（BLAS/LAPACK, MPI via base library, Sec. 2.1）——解决性能障碍：提供与 Fortran/C++ 相当的计算性能，使得 MRSF-TDDFT 适用于中等分子体系（约 50-200 原子），支持并行执行以加速大规模计算；(3) 开源生态（Sec. 1）——解决持续性障碍：开源发布确保代码可持续访问和社区贡献，模块化架构允许外部开发者贡献新的理论方法模块（Sec. 6），基于 BSD/MIT 兼容许可（未明确指定，但文中强调"open-source ecosystem"）降低商业/学术采用的许可顾虑。可视化方面的障碍仍需独立解决——OpenQP 目前未提供内置可视化输出。阅读后回填对问卷题目的影响：可增加关于"模块化架构对可视化工具集成的影响"和"PyOQP 与外部可视化工具互操作"的题目可转化为访谈追问：OpenQP 用户是否需要 MRSF-TDDFT 特有的自旋-翻转跃迁可视化功能关键证据页码/图表：Sec. 1 (开源生态), Sec. 2.1 (模块化架构与 C API), Sec. 2.2 (MRSF-TDDFT), Sec. 2.3 (DTCAM 泛函), Sec. 2.4 (PyOQP), Figure 1 (模块结构图), Figure 4-5,7-10 (光谱/跃迁可视化示例)仍未解决的问题：OpenQP 是否有计划支持通用输出格式（Cube/Molden/HDF5）？综合摘要本文（Mironov et al., J. Chem. Theory Comput. 20, 9464-9477, 2024）介绍了 OpenQP 开源量子化学平台，以模块化架构（Sec. 2.1）解决可持续性和互操作性挑战。核心科学创新是 MRSF-TDDFT（Sec. 2.2）及其 DTCAM 系列泛函（Sec. 2.3），能描述含双激发特征的旋翻激发态。技术架构上采用自主模块间结构化数据类型传参、C API 支持第三方互联、PyOQP Python 封装（Sec. 2.4）提供工作流自动化。可视化需求涵盖 NTO 粒子-空穴对、自旋翻转产生的自旋密度差、锥形交叉双态密度差和吸收光谱归属。模块化 API 设计为外部可视化工具集成提供了可能，但原生输出格式和标准化适配器定义仍有待发展。},
	file = {PDF:D\:\\Zotero\\storage\\FSS3ILKC\\Mironov 等 - 2024 - OpenQP a quantum chemical platform featuring MRSF-TDDFT with an emphasis on open-source ecosystem.pdf:application/pdf},
}

@article{smith_span_2021,
	title = {The {\textless}span style="font-variant:small-caps;"{\textgreater}{MolSSI}{\textless}/span{\textgreater} {QCA} {\textless}span style="font-variant:small-caps;"{\textgreater}rchive{\textless}/span{\textgreater} project: {An} open‐source platform to compute, organize, and share quantum chemistry data},
	volume = {11},
	issn = {1759-0876, 1759-0884},
	shorttitle = {{QCArchive}},
	url = {https://wires.onlinelibrary.wiley.com/doi/10.1002/wcms.1491},
	doi = {10.1002/wcms.1491},
	abstract = {Abstract
            
              The Molecular Sciences Software Institute's (MolSSI) Quantum Chemistry Archive (QCA
              rchive
              ) project is an umbrella name that covers both a central server hosted by MolSSI for community data and the Python‐based software infrastructure that powers automated computation and storage of quantum chemistry (QC) results. The MolSSI‐hosted central server provides the computational molecular sciences community a location to freely access tens of millions of QC computations for machine learning, methodology assessment, force‐field fitting, and more through a Python interface. Facile, user‐friendly mining of the centrally archived quantum chemical data also can be achieved through web applications found at
              https://qcarchive.molssi.org
              . The software infrastructure can be used as a standalone platform to compute, structure, and distribute hundreds of millions of QC computations for individuals or groups of researchers at any scale. The QCA
              rchive
              I
              nfrastructure
              is open‐source (BSD‐3C), code repositories can be found at
              https://github.com/MolSSI
              , and releases can be downloaded via PyPI and Conda.
            
            
              This article is categorized under:
              
                
                  Electronic Structure Theory {\textgreater} Ab Initio Electronic Structure Methods
                
                
                  Software {\textgreater} Quantum Chemistry
                
                
                  Data Science {\textgreater} Computer Algorithms and Programming},
	language = {en},
	number = {2},
	journal = {WIREs Computational Molecular Science},
	author = {Smith, Daniel G. A. and Altarawy, Doaa and Burns, Lori A. and Welborn, Matthew and Naden, Levi N. and Ward, Logan and Ellis, Sam and Pritchard, Benjamin P. and Crawford, T. Daniel},
	month = mar,
	year = {2021},
	pages = {e1491},
	annote = {Survey 定向阅读问题
关联模块： QCArchive、数据模型与可追溯
问题生成依据： 题名与 Zotero 摘要
阅读时请直接在每个"回答"后补充结论，并记录对应页码、图表或原文位置。
阅读问题
问题 1
QCArchive 如何把输入、输出、程序版本和执行来源组织为可复现记录？
回答：
QCArchive 通过多层架构实现完整的可复现记录：

QCSCHEMA 标准化文档：所有计算输入输出都使用 QCSCHEMA 规范文档（如 AtomicInput 描述原子计算的标准输入），"the input QCSCHEMA completely specifies and documents the calculation that was performed"（Section 3.2.2, p.5）。
同一文档整合输入/来源/输出："The inputs, provenance, and outputs of a calculation are all stored in the same document, which makes it less likely that metadata will be lost"（Section 3.2.2, p.5）。这是阻止元数据丢失的关键设计。
自动收集来源信息：QCENGINE 自动记录 "program version, hardware specification, physical resources utilized, and QCENGINE version"（Section 3.2.2, p.5）。
唯一标识符防重复：QCFRACTAL 数据库中每个对象有唯一标识符，"a single-point computation: molecule, method, basis, program, and a unique keyword set identifier, which together describe a unique computation"（Section 3.2.3, p.6）。
物理常数版本控制：QCELEMENTAL 收集物理常数并标定上下文（如 CODATA2018），"with a context switch, conversions to older data are reproducible"（Section 3.2.1, p.4）。数值以原子单位存储以"minimize susceptibility to such details"。
软件最佳实践：整个项目遵循 MolSSI 的软件"Best Practices"指南，月度发布周期自动部署到 PyPI、Conda 和 Docker（Section 3.1, p.3-4）。

关键启示：本项目可借鉴"同一文档保存输入/来源/输出"的设计模式，将三维场数据的源程序、程序版本、输入参数、输出轨道信息与元数据捆绑在同一容器中。
问题 2
能量/梯度/Hessian 与轨道/场数据应如何关联到同一计算记录？
回答：

引用式关联：QCFRACTAL 采用关系型数据库（PostgreSQL），"each type of QCELEMENTAL object stored (Molecule, AtomicResult, etc.) has its own table"（Section 3.2.3, p.6）。Composite 对象（如 AtomicResult）"reference the required table instead of storing the object"——例如单个 Molecule 对象可以被多个能量或梯度计算引用，不会被重复存储，且所有相关计算可快速查询（Section 3.2.3, p.6）。
轨道数据的特殊处理：论文特意指出 "Orbitals and other atomic orbitals quantities radically increase the total size and are stored sparingly"（Footnote 1, p.12）。这表明即使在 QCArchive 中，轨道/场数据的存储策略与标量数据（能量/梯度/Hessian）有本质不同。
支持的数据类型：MQCAS 存储的数据包括 "geometries, energies, nuclear Hessians, electrostatic potentials, and wavefunctions"（Section 1, p.2）——其中 wavefunctions 和 electrostatic potentials 就是三维场数据的前身。
对本项目的启示：能量/梯度等小数据可采用 QCArchive 的引用模式（直接关联到同一 Molecule 记录），而轨道系数/波函数/三维场数据应"sparingly"存储，可采用外部文件（如 .cube / OpenVDB）引用而非嵌入数据库记录。QCArchive 的 "unique identifier" 机制可用于将场数据与标量计算记录关联。

问题 3
用户愿意上传、共享或本地部署哪些数据，隐私和数据规模会造成什么障碍？
回答：

本地部署支持：QCARCHIVE INFRASTRUCTURE 支持完全私有实例——"Private QCARCHIVE INFRASTRUCTURE instances are fully as capable as MQCAS but are isolated from the public MQCAS"（Section 2, p.3）。用户有完全控制权，仅在用户选择时才共享数据。
成本激励：论文的核心论点是存储的巨大性价比——"storing QC data is currently 50,000–100,000 times cheaper than regenerating it"（Section 1, p.2）。估计每 TB 可存储 5 亿个计算结果（成本 \$200–500），对应约 10 亿美元的计算时间。
多领域专业技能门槛："A common complaint that MolSSI has heard after interviewing over a hundred groups is that producing useful large-scale quantum chemical research datasets requires considerable specialized expertise in multiple domains (cheminformatics, QC, high-performance computing, database management)"（Section 1, p.2）。
数据审核：社区提交的数据集"are reviewed by the MQCAS maintainers for integrity and often require comparisons to literature values to ensure consistency before accepting a contribution"（Section 2, p.3）。
轨道数据规模的限制：虽然标量数据仅 {\textasciitilde}2 kB/计算，但 "Orbitals and other atomic orbitals quantities radically increase the total size and are stored sparingly"（Footnote 1, p.12）。对于本项目涉及的三维场数据（cube 文件通常 10-100 MB+），存储策略必须谨慎设计。

阅读后回填

对问卷题目或选项的影响： 模块 C（三维场文件格式）应包含问题"你是否愿意将轨道/场数据上传到共享仓库（类似 QCArchive）？"；模块 B 应纳入"计算的可复现性记录（程序版本、输入参数、来源信息）是否影响你对结果可信度的评估？"
可转化为访谈追问的内容： "你的计算数据目前保存在哪里（本地、共享仓库、补充材料）？共享计算数据时你最担心什么（隐私、格式、工作量、版权）？" "你是否愿意为三维场数据建立类似 QCArchive 的共享仓库？"
关键证据页码/图表： Section 3.2.2 p.5（同一文档存储输入/来源/输出 + 自动来源记录）；Section 3.2.3 p.6（唯一标识符 + 对象引用结构）；Section 1 p.2 + Footnote 1 p.12（标量 vs 轨道数据规模差异的量化证据）；Figure 4 p.7（架构通信图）。
仍未解决的问题： 论文未详细说明 QCSCHEMA 如何具体描述轨道/wavefunction 数据；也未讨论场数据（如静电势网格、电子密度 cube）的标准表示方式。

总结
QCArchive 是 FAIR 数据原则在量子化学中的成功实践——其 MQCAS 已包含 1400 万个分子和 2100 万条计算结果记录。对本项目的关键启示：(1) "同一文档存储输入+来源+输出" 的设计模式可直接应用于三维场数据的元数据封装；(2) 对象引用（而非复制）的数据库模式提示场数据应通过唯一标识符与计算记录关联，而非内嵌存储；(3) 轨道/场数据的 "size radically increase" 问题必须在设计之初就考虑——我们的 OpenVDB 方法本质上正是解决大规模稀疏场数据高效存储的方案；(4) 私有部署支持是缓解用户隐私顾虑的关键功能。},
	file = {全文:D\:\\Zotero\\storage\\8T7TTNJ5\\Smith 等 - 2021 - The MolSSI QCA .pdf:application/pdf},
}

@article{barnes_molssi_2021,
	title = {The {MolSSI} {Driver} {Interface} {Project}: {A} framework for standardized, on-the-fly interoperability between computational molecular sciences codes},
