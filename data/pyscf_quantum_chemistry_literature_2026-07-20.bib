	volume = {59},
	issn = {1549-9596, 1549-960X},
	shorttitle = {New basis set exchange},
	url = {https://pubs.acs.org/doi/10.1021/acs.jcim.9b00725},
	doi = {10.1021/acs.jcim.9b00725},
	language = {en},
	number = {11},
